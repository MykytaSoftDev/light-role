FROM node:20-alpine AS base

FROM base AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app
COPY package*.json ./
RUN npm ci

FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID
ARG NEXT_PUBLIC_PADDLE_CLIENT_TOKEN
ARG NEXT_PUBLIC_PADDLE_ENVIRONMENT
ARG NEXT_PUBLIC_PADDLE_PRICE_ID_PRO_MONTHLY
ARG NEXT_PUBLIC_PADDLE_PRICE_ID_PRO_ANNUAL
ARG NEXT_PUBLIC_PADDLE_PRICE_ID_UNLIMITED_MONTHLY
ARG NEXT_PUBLIC_PADDLE_PRICE_ID_UNLIMITED_ANNUAL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=$NEXT_PUBLIC_GOOGLE_CLIENT_ID
ENV NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=$NEXT_PUBLIC_PADDLE_CLIENT_TOKEN
ENV NEXT_PUBLIC_PADDLE_ENVIRONMENT=$NEXT_PUBLIC_PADDLE_ENVIRONMENT
ENV NEXT_PUBLIC_PADDLE_PRICE_ID_PRO_MONTHLY=$NEXT_PUBLIC_PADDLE_PRICE_ID_PRO_MONTHLY
ENV NEXT_PUBLIC_PADDLE_PRICE_ID_PRO_ANNUAL=$NEXT_PUBLIC_PADDLE_PRICE_ID_PRO_ANNUAL
ENV NEXT_PUBLIC_PADDLE_PRICE_ID_UNLIMITED_MONTHLY=$NEXT_PUBLIC_PADDLE_PRICE_ID_UNLIMITED_MONTHLY
ENV NEXT_PUBLIC_PADDLE_PRICE_ID_UNLIMITED_ANNUAL=$NEXT_PUBLIC_PADDLE_PRICE_ID_UNLIMITED_ANNUAL
RUN npm run build

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
CMD ["node", "server.js"]
