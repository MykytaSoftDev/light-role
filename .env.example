# =============================================================
# Light Role — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# PostgreSQL
POSTGRES_USER=lightrole
POSTGRES_PASSWORD=lightrole
POSTGRES_DB=lightrole

# JWT Security (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production

# OpenAI
OPENAI_API_KEY=

# Resend (email service)
RESEND_API_KEY=
# Sender address — must be a verified domain in Resend, or use onboarding@resend.dev for testing
RESEND_FROM_EMAIL=onboarding@resend.dev

# Sentry (optional, leave empty to disable)
SENTRY_DSN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
