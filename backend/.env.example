# Application
APP_NAME=Light Role API
DEBUG=false
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://lightrole:lightrole@localhost:5432/lightrole

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
FRONTEND_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SUPPORT_EMAIL=support@lightrole.com

# Sentry (optional)
SENTRY_DSN=

# File storage
UPLOADS_DIR=/uploads
MAX_FILE_SIZE_MB=10

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PDF rendering (TAILOR-3)
# Hard cap on a single page.pdf() render in seconds (504 on timeout).
PDF_RENDER_TIMEOUT_SECONDS=20
# Recycle the singleton Chromium browser after this many successful renders
# to bound memory growth.
PDF_BROWSER_RECYCLE_AFTER=200

# Paddle
PADDLE_PRICE_MONTHLY=pri_xxx
PADDLE_PRICE_ANNUAL=pri_xxx
PADDLE_WEBHOOK_SECRET=pdl_xxx
PADDLE_ENVIRONMENT=sandbox
