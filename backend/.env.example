# Application
APP_NAME=Light Role API
DEBUG=false
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://lightrole:lightrole@localhost:5432/lightrole

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
FRONTEND_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=

# Resend (email)
RESEND_API_KEY=

# Sentry (optional)
SENTRY_DSN=

# File storage
UPLOADS_DIR=/uploads
MAX_FILE_SIZE_MB=10

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
