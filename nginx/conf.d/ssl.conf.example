# SSL configuration template for production
# Copy to ssl.conf and update certificate paths

server {
    listen 443 ssl http2;
    server_name lightrole.com www.lightrole.com;

    ssl_certificate /etc/letsencrypt/live/lightrole.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/lightrole.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    add_header Strict-Transport-Security "max-age=63072000" always;

    # ... same location blocks as default.conf ...
}

server {
    listen 80;
    server_name lightrole.com www.lightrole.com;
    return 301 https://$host$request_uri;
}
